# Startup config for next-runner.mjs
# Copy this file to .env.local and modify values for your machine.

# Preferred custom vars
LCR_PORT=3100
LCR_HOST=127.0.0.1
LCR_TURBOPACK=true

# Optional standard vars (LCR_* has higher priority)
# PORT=3100
# HOSTNAME=127.0.0.1

# Optional
NEXT_TELEMETRY_DISABLED=1

# Prisma / SQLite
DATABASE_URL="file:./dev.db"

# OCR service
# Used by Next.js server-side API routes to call the PaddleOCR service.
OCR_API_URL="http://127.0.0.1:8001"
OCR_API_TIMEOUT_MS="180000"
OCR_ACCURACY_TRACKING_ENABLED=true
NEXT_PUBLIC_OCR_ACCURACY_TRACKING_ENABLED=true
